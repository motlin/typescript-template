{
	"name": "@your-org/typescript-template",
	"version": "0.0.0",
	"description": "A standardized TypeScript project template",
	"type": "module",
	"scripts": {
		"dev": "vp dev",
		"preview": "vp preview",
		"build": "tsgo && vp build",
		"oxlint": "vp lint . --fix",
		"oxlint:ci": "vp lint . --format github",
		"fmt": "vp fmt",
		"fmt:ci": "vp fmt --check",
		"typecheck": "tsgo --noEmit",
		"test": "node node_modules/vitest/dist/cli.js",
		"test:ui": "node node_modules/vitest/dist/cli.js --ui",
		"test:run": "node node_modules/vitest/dist/cli.js run",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"test-storybook": "npx concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npx http-server storybook-static --port 6006 --silent\" \"npx wait-on tcp:127.0.0.1:6006 && test-storybook\"",
		"prepare": "vp config"
	},
	"dependencies": {
		"lucide-react": "^1.7.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.1",
		"@sentry/vite-plugin": "^5.1.1",
		"@storybook/addon-a11y": "^10.3.3",
		"@storybook/addon-docs": "^10.3.3",
		"@storybook/addon-onboarding": "^10.3.3",
		"@storybook/addon-vitest": "^10.3.3",
		"@storybook/react-vite": "^10.3.3",
		"@storybook/test-runner": "^0.24.3",
		"@tanstack/react-query-devtools": "^5.96.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260401.1",
		"@vitejs/plugin-react": "^6.0.1",
		"eslint": "^10.1.0",
		"eslint-plugin-storybook": "^10.3.3",
		"jiti": "^2.5.0",
		"jsdom": "^29.0.1",
		"playwright": "^1.59.1",
		"storybook": "^10.3.4",
		"vite": "catalog:",
		"vite-plus": "catalog:",
		"vitest": "catalog:"
	},
	"packageManager": "pnpm@10.33.0"
}
