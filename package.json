{
	"name": "@your-org/typescript-template",
	"version": "0.0.0",
	"description": "A standardized TypeScript project template",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"preview": "vite preview",
		"build": "tsgo && vite build",
		"oxlint": "oxlint . --fix",
		"oxlint:ci": "oxlint . --format github",
		"biome": "npx biome format --write .",
		"biome:ci": "npx biome format .",
		"prettier": "prettier --write .",
		"prettier:ci": "prettier --check \"src/**/*.{js,ts,css,md,json}\"",
		"format": "npx biome format --write . && prettier --write .",
		"typecheck": "tsgo --noEmit",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:run": "vitest run",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"test-storybook": "npx concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npx http-server storybook-static --port 6006 --silent\" \"npx wait-on tcp:127.0.0.1:6006 && test-storybook\""
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@chromatic-com/storybook": "^5.0.2",
		"@sentry/vite-plugin": "^5.1.1",
		"@storybook/addon-a11y": "^10.3.3",
		"@storybook/addon-docs": "^10.3.3",
		"@storybook/addon-onboarding": "^10.3.3",
		"@storybook/addon-vitest": "^10.3.3",
		"@storybook/react-vite": "^10.3.3",
		"@storybook/test-runner": "^0.24.3",
		"@tanstack/react-query-devtools": "^5.95.2",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260324.1",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^4.1.1",
		"@vitest/browser-playwright": "^4.1.1",
		"@vitest/coverage-v8": "^4.1.1",
		"eslint": "^10.1.0",
		"eslint-plugin-storybook": "^10.3.2",
		"jiti": "^2.5.0",
		"jsdom": "^29.0.1",
		"oxlint": "^1.57.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"storybook": "^10.3.3",
		"vite": "^8.0.2",
		"vitest": "^4.1.1",
		"vitest-browser-react": "^2.1.0"
	},
	"dependencies": {
		"lucide-react": "^1.6.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	}
}
